{
  "expo": {
    "name": "EcoGuard",
    "slug": "ecoguard",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "scheme": "ecoguard",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#030a12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ecoguard.pipeline"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#030a12"
      },
      "package": "com.ecoguard.pipeline"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:8000",
      "wsUrl": "ws://localhost:8000",
      "router": {},
      "eas": {
        "projectId": "0fbfcdaa-aa9e-4b0a-9752-44889e5d9a2f"
      }
    },
    "owner": "oggskimmer"
  }
}